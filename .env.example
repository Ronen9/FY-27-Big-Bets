# Copy this file to `.env` and fill in your values. The deck-builder server
# (tools/deck-builder/server.py) reads from .env at startup.
#
# .env is gitignored — never commit it.

# ─── Azure OpenAI (default backend) ────────────────────────────────────────
# Required when LLM_BACKEND is unset or "aoai".

# Your Azure OpenAI resource endpoint (no trailing slash).
AZURE_OPENAI_ENDPOINT=https://your-aoai-resource.openai.azure.com

# The deployment name in your AOAI resource. Tested with gpt-4.1.
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Pin a stable API version that matches your deployment.
AZURE_OPENAI_API_VERSION=2024-10-21

# Tenant ID for `az login` and Entra-token-based auth.
AZURE_OPENAI_TENANT_ID=00000000-0000-0000-0000-000000000000

# Optional: API key fallback if managed identity / az login isn't available.
# AZURE_OPENAI_API_KEY=

# ─── Cohere (optional alternative backend) ─────────────────────────────────
# Set this if you want to use Cohere instead. The server auto-selects Cohere
# when COHERE_API_KEY is present, unless you force a backend explicitly.
# COHERE_API_KEY=

# Force a specific backend regardless of which keys are set:
# LLM_BACKEND=aoai
# LLM_BACKEND=cohere

# ─── Magic-picker web search (optional) ────────────────────────────────────
# Used by the "✨ Magic Picker" mode to pull a one-line "why" per account
# from public sources. The picker still works without this — it just falls
# back to the structured pipeline signal.
# TAVILY_API_KEY=

# ─── Server runtime ────────────────────────────────────────────────────────
# DECK_BUILDER_PORT=8765
# OPEN_SLIDE_DEV_URL=http://localhost:5173
